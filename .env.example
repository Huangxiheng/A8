# 日志配置
# 日志文件路径（相对于项目根目录）
LOG_FILE_PATH=./logs/app.log
# 日志输出模式：console（仅控制台）| file（仅文件）| both（同时输出到控制台和文件）
LOG_OUTPUT_MODE=both
# 日志级别：error | warn | info | debug | verbose | silly
LOG_LEVEL=info

# Seeyon API 认证配置
# 用户名（未设置时使用 examples 中的默认值）
SEYON_USERNAME=
# 密码（未设置时使用 examples 中的默认值）
SEYON_PASSWORD=
